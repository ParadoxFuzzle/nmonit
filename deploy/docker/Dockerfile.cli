# Multi-stage Dockerfile for the CLI tool
FROM golang:1.22-bookworm AS builder

WORKDIR /build
COPY cli/go.mod cli/go.sum ./
RUN go mod download

COPY cli/ .

RUN CGO_ENABLED=0 go build -o compute ./...

FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /build/compute /compute

ENTRYPOINT ["/compute"]
